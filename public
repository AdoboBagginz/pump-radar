<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PUMP RADAR — Live Solana Screener</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–bg:      #030508;
–surface: #07090f;
–panel:   #090d18;
–card:    #0b1020;
–border:  #111c2e;
–accent:  #00ffcc;
–red:     #ff2d55;
–orange:  #ff7a00;
–yellow:  #ffe234;
–green:   #00e676;
–purple:  #d050ff;
–dim:     #253550;
–muted:   #3a5272;
–text:    #b0ccee;
–hi:      #ddeeff;
}

body {
background: var(–bg);
color: var(–text);
font-family: ‘Share Tech Mono’, monospace;
font-size: 12px;
min-height: 100vh;
overflow-x: hidden;
}

/* scanlines */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,255,204,0.006) 2px, rgba(0,255,204,0.006) 4px);
pointer-events: none;
z-index: 9999;
}

/* ── HEADER ── */
#header {
display: flex;
align-items: center;
justify-content: space-between;
padding: 10px 16px;
border-bottom: 1px solid var(–border);
background: var(–surface);
position: sticky;
top: 0;
z-index: 100;
gap: 12px;
flex-wrap: wrap;
}

.logo {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 26px;
letter-spacing: 5px;
color: var(–accent);
text-shadow: 0 0 25px rgba(0,255,204,0.5);
line-height: 1;
white-space: nowrap;
}
.logo span { color: var(–purple); font-size: 10px; letter-spacing: 2px; vertical-align: super; }

#status-bar {
display: flex;
align-items: center;
gap: 14px;
flex-wrap: wrap;
}

.status-dot {
width: 8px; height: 8px;
border-radius: 50%;
background: var(–dim);
flex-shrink: 0;
transition: background 0.3s;
}
.status-dot.live   { background: var(–green);  box-shadow: 0 0 10px var(–green);  animation: pulse 1.5s infinite; }
.status-dot.error  { background: var(–red);    box-shadow: 0 0 10px var(–red); }
.status-dot.conn   { background: var(–yellow); box-shadow: 0 0 8px var(–yellow); animation: pulse 1s infinite; }

#status-text { color: var(–muted); font-size: 10px; letter-spacing: 1px; }
#stat-tokens { color: var(–accent); }
#stat-scans  { color: var(–muted); }
#stat-alerts { color: var(–orange); }
#last-scan   { color: var(–dim); font-size: 9px; }

/* ── CONTROLS ── */
#controls {
display: flex;
gap: 8px;
padding: 8px 16px;
border-bottom: 1px solid var(–border);
background: var(–panel);
align-items: center;
flex-wrap: wrap;
}

.ctrl-label { color: var(–dim); font-size: 9px; letter-spacing: 1.5px; margin-right: 2px; }

select, input[type=“number”], input[type=“text”] {
background: var(–card);
border: 1px solid var(–border);
color: var(–text);
padding: 4px 8px;
font-family: ‘Share Tech Mono’, monospace;
font-size: 11px;
outline: none;
transition: border-color 0.2s;
}
select:focus, input:focus { border-color: var(–accent); }

.btn {
background: transparent;
border: 1px solid var(–border);
color: var(–muted);
padding: 4px 12px;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 13px;
letter-spacing: 1.5px;
cursor: pointer;
transition: all 0.15s;
}
.btn:hover    { border-color: var(–accent); color: var(–accent); }
.btn.active   { border-color: var(–accent); color: var(–accent); background: rgba(0,255,204,0.06); }
.btn.danger   { border-color: var(–red); color: var(–red); }
.btn.danger.active { background: rgba(255,45,85,0.08); }

/* ── LAYOUT ── */
#main {
display: grid;
grid-template-columns: 1fr 320px;
height: calc(100vh - 96px);
overflow: hidden;
}

/* ── TOKEN TABLE ── */
#table-wrap {
overflow-y: auto;
border-right: 1px solid var(–border);
}

table {
width: 100%;
border-collapse: collapse;
font-size: 11px;
}

thead th {
background: var(–panel);
color: var(–dim);
font-size: 9px;
letter-spacing: 1.5px;
padding: 7px 10px;
text-align: left;
position: sticky;
top: 0;
cursor: pointer;
user-select: none;
white-space: nowrap;
border-bottom: 1px solid var(–border);
}
thead th:hover { color: var(–accent); }
thead th.sort-asc::after  { content: ’ ▲’; color: var(–accent); }
thead th.sort-desc::after { content: ’ ▼’; color: var(–accent); }

tbody tr {
border-bottom: 1px solid rgba(17,28,46,0.7);
cursor: pointer;
transition: background 0.15s;
}
tbody tr:hover          { background: rgba(0,255,204,0.04); }
tbody tr.selected       { background: rgba(0,255,204,0.07); }
tbody tr.flash-buy      { animation: flashBuy  0.6s ease; }
tbody tr.flash-sell     { animation: flashSell 0.6s ease; }
tbody tr.row-new        { border-left: 2px solid var(–purple); }

tbody td {
padding: 7px 10px;
white-space: nowrap;
vertical-align: middle;
}

.sym { font-family: ‘Bebas Neue’, sans-serif; font-size: 15px; letter-spacing: 1px; color: var(–hi); }
.name-sub { font-size: 8px; color: var(–dim); margin-top: 1px; }

.price { color: #8ab8f0; font-size: 12px; }

.chg { font-size: 11px; }
.chg.pos { color: var(–green); }
.chg.neg { color: var(–red); }
.chg.neu { color: var(–muted); }

.verdict-badge {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 11px;
letter-spacing: 1px;
padding: 2px 7px;
border-radius: 2px;
white-space: nowrap;
}
.v-sb  { background: rgba(0,230,118,0.18); color: var(–green);  border: 1px solid rgba(0,230,118,0.4); }
.v-b   { background: rgba(0,230,118,0.08); color: #4cde8a;       border: 1px solid rgba(0,230,118,0.2); }
.v-n   { background: transparent;          color: var(–muted);  border: 1px solid var(–border); }
.v-s   { background: rgba(255,45,85,0.08); color: #ff6b8a;       border: 1px solid rgba(255,45,85,0.2); }
.v-ss  { background: rgba(255,45,85,0.18); color: var(–red);    border: 1px solid rgba(255,45,85,0.4); }

.score-bar-wrap { display: flex; align-items: center; gap: 5px; min-width: 70px; }
.score-bar { flex: 1; height: 4px; background: var(–dim); border-radius: 2px; overflow: hidden; }
.score-bar-fill { height: 100%; border-radius: 2px; transition: width 0.4s ease; }
.score-num { font-size: 10px; min-width: 22px; text-align: right; }

.safe-num { font-size: 10px; }

.liq-num { color: var(–muted); font-size: 10px; }
.vol-num { color: var(–text); font-size: 10px; }

.buysell { display: flex; gap: 3px; align-items: center; font-size: 10px; }
.bs-b { color: var(–green); }
.bs-s { color: var(–red); }
.bs-bar { width: 40px; height: 5px; background: var(–dim); border-radius: 2px; overflow: hidden; }
.bs-fill { height: 100%; background: var(–green); border-radius: 2px; transition: width 0.4s; }

.age-tag {
font-size: 9px; padding: 1px 5px;
border: 1px solid var(–border);
color: var(–muted);
}
.age-tag.new1 { border-color: var(–purple); color: var(–purple); }
.age-tag.new6 { border-color: var(–orange); color: var(–orange); }

.dex-tag { font-size: 9px; color: var(–dim); }

/* ── SIDEBAR ── */
#sidebar {
display: flex;
flex-direction: column;
overflow: hidden;
background: var(–panel);
}

.sidebar-section {
border-bottom: 1px solid var(–border);
flex-shrink: 0;
}
.sidebar-title {
font-size: 9px;
letter-spacing: 2px;
color: var(–dim);
padding: 8px 12px;
background: var(–surface);
border-bottom: 1px solid var(–border);
}

/* Detail panel */
#detail {
flex: 1;
overflow-y: auto;
padding: 12px;
min-height: 0;
}
.detail-empty {
display: flex; align-items: center; justify-content: center;
height: 100%; color: var(–dim); font-size: 11px; letter-spacing: 2px;
text-align: center;
}
.detail-sym {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 28px; letter-spacing: 3px;
color: var(–accent); line-height: 1;
margin-bottom: 2px;
}
.detail-name { color: var(–muted); font-size: 9px; margin-bottom: 10px; }
.detail-price {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px; color: #8ab8f0; letter-spacing: 1px;
margin-bottom: 10px;
}
.detail-grid {
display: grid; grid-template-columns: 1fr 1fr;
gap: 6px; margin-bottom: 12px;
}
.detail-cell {
background: var(–card); border: 1px solid var(–border);
padding: 7px 9px;
}
.detail-cell-label { font-size: 7px; color: var(–dim); letter-spacing: 2px; margin-bottom: 3px; }
.detail-cell-val   { font-size: 12px; color: var(–text); }

.signals-list { display: flex; flex-direction: column; gap: 4px; margin-bottom: 12px; }
.signal-item {
display: flex; align-items: center; justify-content: space-between;
padding: 5px 9px; font-size: 10px;
border-left: 3px solid var(–border);
}
.signal-item.BUY-STRONG  { border-color: var(–green);  background: rgba(0,230,118,0.07); }
.signal-item.BUY-WEAK    { border-color: #4cde8a;        background: rgba(0,230,118,0.04); }
.signal-item.SELL-STRONG { border-color: var(–red);    background: rgba(255,45,85,0.07); }
.signal-item.SELL-WEAK   { border-color: var(–orange); background: rgba(255,122,0,0.04); }
.signal-item.WARN-DANGER { border-color: var(–red);    background: rgba(255,45,85,0.05); }
.signal-item.WARN-WARN   { border-color: var(–yellow); background: rgba(255,226,52,0.05); }
.signal-item.INFO-INFO   { border-color: var(–muted);  background: transparent; }
.sig-label  { color: var(–text); }
.sig-detail { color: var(–muted); font-size: 9px; }

.detail-links { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; }
.detail-link {
display: block; text-align: center; text-decoration: none;
font-family: ‘Bebas Neue’, sans-serif; font-size: 12px; letter-spacing: 1.5px;
padding: 8px 4px;
border: 1px solid var(–border); color: var(–muted);
transition: all 0.15s;
}
.detail-link:hover { background: var(–accent); color: #000; border-color: var(–accent); }
.detail-link.jup:hover  { background: var(–green);  border-color: var(–green);  color: #000; }
.detail-link.rug:hover  { background: var(–red);    border-color: var(–red);    color: #fff; }
.detail-link.dex:hover  { background: var(–accent); border-color: var(–accent); color: #000; }

/* Alert log */
#alerts-wrap { height: 200px; overflow-y: auto; }
.alert-item {
padding: 6px 10px;
border-bottom: 1px solid rgba(17,28,46,0.5);
display: flex; gap: 8px; align-items: flex-start;
font-size: 10px;
animation: slideIn 0.3s ease;
}
.alert-item.buy  { border-left: 2px solid var(–green); }
.alert-item.sell { border-left: 2px solid var(–red); }
.alert-item.warn { border-left: 2px solid var(–yellow); }
.alert-sym   { font-family: ‘Bebas Neue’, sans-serif; font-size: 13px; color: var(–hi); flex-shrink:0; }
.alert-body  { flex: 1; }
.alert-verdict { font-size: 9px; margin-bottom: 1px; }
.alert-sigs  { color: var(–muted); font-size: 9px; }
.alert-time  { color: var(–dim); font-size: 9px; flex-shrink: 0; }
.alerts-empty { padding: 16px; text-align: center; color: var(–dim); font-size: 10px; letter-spacing: 1px; }

/* Scrollbars */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(–surface); }
::-webkit-scrollbar-thumb { background: var(–border); border-radius: 2px; }

/* Animations */
@keyframes pulse    { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.7)} }
@keyframes flashBuy { 0%{background:rgba(0,230,118,0.22)} 100%{background:transparent} }
@keyframes flashSell{ 0%{background:rgba(255,45,85,0.22)}  100%{background:transparent} }
@keyframes slideIn  { from{opacity:0;transform:translateX(10px)} to{opacity:1;transform:none} }
@keyframes newRow   { from{opacity:0;transform:translateY(-4px)} to{opacity:1;transform:none} }

.row-enter { animation: newRow 0.4s ease; }

/* Mobile */
@media (max-width: 768px) {
#main { grid-template-columns: 1fr; }
#sidebar { display: none; }
.hide-mobile { display: none; }
}
</style>

</head>
<body>

<!-- HEADER -->

<div id="header">
  <div style="display:flex;align-items:center;gap:10px">
    <div class="logo">PUMP RADAR <span>PRO</span></div>
    <div id="ws-url-display" style="font-size:9px;color:var(--dim);letter-spacing:1px"></div>
  </div>
  <div id="status-bar">
    <div class="status-dot" id="dot"></div>
    <span id="status-text">CONNECTING...</span>
    <span style="color:var(--border)">|</span>
    <span class="ctrl-label">TOKENS</span><span id="stat-tokens">0</span>
    <span style="color:var(--border)">|</span>
    <span class="ctrl-label">SCANS</span><span id="stat-scans">0</span>
    <span style="color:var(--border)">|</span>
    <span class="ctrl-label">ALERTS</span><span id="stat-alerts">0</span>
    <span id="last-scan"></span>
  </div>
  <div style="display:flex;align-items:center;gap:8px">
    <label class="ctrl-label">WS URL</label>
    <input type="text" id="ws-input" placeholder="wss://your-app.railway.app" style="width:220px" />
    <button class="btn" onclick="connectWS()">CONNECT</button>
  </div>
</div>

<!-- CONTROLS -->

<div id="controls">
  <span class="ctrl-label">FILTER</span>
  <button class="btn active" data-filter="all"         onclick="setFilter(this,'all')">ALL</button>
  <button class="btn"        data-filter="strong_buy"  onclick="setFilter(this,'strong_buy')">🟢 STRONG BUY</button>
  <button class="btn"        data-filter="buy"         onclick="setFilter(this,'buy')">BUY</button>
  <button class="btn danger" data-filter="strong_sell" onclick="setFilter(this,'strong_sell')">🔴 STRONG SELL</button>
  <button class="btn"        data-filter="new1h"       onclick="setFilter(this,'new1h')">⚡ <1H</button>
  <button class="btn"        data-filter="new6h"       onclick="setFilter(this,'new6h')">🆕 <6H</button>

<span style="margin-left:8px" class="ctrl-label">MIN LIQ</span>
<input type="number" id="min-liq" value="5000" step="1000" style="width:80px" onchange="applyFilters()">

<span class="ctrl-label">MIN VOL 5M</span>
<input type="number" id="min-vol5m" value="0" step="100" style="width:70px" onchange="applyFilters()">

<span class="ctrl-label">MIN SCORE</span>
<input type="number" id="min-score" value="0" max="100" style="width:50px" onchange="applyFilters()">

<span class="ctrl-label" style="margin-left:8px">SORT</span>
<select id="sort-select" onchange="applyFilters()">
<option value="score">Score</option>
<option value="vol5m">Vol 5m</option>
<option value="c5m">% 5m</option>
<option value="c1h">% 1h</option>
<option value="liquidity">Liquidity</option>
<option value="age">Newest</option>
</select>

<button class="btn" onclick="clearAlerts()" style="margin-left:auto">CLEAR ALERTS</button>

</div>

<!-- MAIN -->

<div id="main">
  <!-- TOKEN TABLE -->
  <div id="table-wrap">
    <table>
      <thead>
        <tr>
          <th>TOKEN</th>
          <th>PRICE</th>
          <th>5M%</th>
          <th>1H%</th>
          <th>VERDICT</th>
          <th>SCORE</th>
          <th>BUYS/SELLS 5M</th>
          <th class="hide-mobile">LIQ</th>
          <th class="hide-mobile">VOL 5M</th>
          <th class="hide-mobile">AGE</th>
          <th class="hide-mobile">DEX</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
    <div id="table-empty" style="padding:40px;text-align:center;color:var(--dim);letter-spacing:2px;font-size:11px">
      ENTER YOUR RAILWAY WEBSOCKET URL ABOVE AND CLICK CONNECT
    </div>
  </div>

  <!-- SIDEBAR -->

  <div id="sidebar">
    <!-- Detail panel -->
    <div class="sidebar-section" style="flex:1;display:flex;flex-direction:column;min-height:0">
      <div class="sidebar-title">TOKEN DETAIL</div>
      <div id="detail">
        <div class="detail-empty">← SELECT A TOKEN</div>
      </div>
    </div>
    <!-- Alert log -->
    <div class="sidebar-section" style="flex-shrink:0">
      <div class="sidebar-title" style="display:flex;justify-content:space-between">
        <span>SIGNAL ALERTS</span>
        <span id="alert-count" style="color:var(--orange)">0</span>
      </div>
      <div id="alerts-wrap">
        <div class="alerts-empty" id="alerts-empty">No signals yet</div>
      </div>
    </div>
  </div>
</div>

<script>
// ── STATE ────────────────────────────────────────────────────────────────────
let ws           = null;
let tokenStore   = new Map();   // address → token
let filteredList = [];
let selectedAddr = null;
let alertCount   = 0;
let activeFilter = "all";
let sortBy       = "score";
let autoScroll   = true;

// ── FORMAT HELPERS ───────────────────────────────────────────────────────────
const fmtN = n => {
  if (!n || isNaN(n)) return "0";
  if (n >= 1e9) return (n/1e9).toFixed(2)+"B";
  if (n >= 1e6) return (n/1e6).toFixed(2)+"M";
  if (n >= 1e3) return (n/1e3).toFixed(1)+"K";
  return Number(n).toFixed(0);
};

const fmtPrice = p => {
  p = parseFloat(p); if (!p) return "$0";
  if (p >= 1)      return "$"+p.toFixed(4);
  if (p >= 0.001)  return "$"+p.toFixed(6);
  const e = Math.floor(Math.log10(Math.abs(p)));
  return "$"+p.toFixed(Math.min(Math.abs(e)+4, 10));
};

const fmtTime = ts => {
  const d = new Date(ts);
  return d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit',second:'2-digit'});
};

const ageStr = ts => {
  const s = (Date.now()-ts)/1000;
  if (s < 60)    return Math.round(s)+"s";
  if (s < 3600)  return Math.round(s/60)+"m";
  if (s < 86400) return (s/3600).toFixed(0)+"h";
  return (s/86400).toFixed(0)+"d";
};

const scoreColor = s =>
  s>=72?"#00e676" : s>=58?"#4cde8a" : s>=42?"#3a5272" : s>=28?"#ff6b8a" : "#ff2d55";

// ── WEBSOCKET ────────────────────────────────────────────────────────────────
function getWsUrl() {
  const input = document.getElementById("ws-input").value.trim();
  if (input) return input;
  // Auto-detect: if served from Railway, use same host
  const proto = location.protocol === "https:" ? "wss:" : "ws:";
  return `${proto}//${location.host}`;
}

function connectWS() {
  if (ws) { ws.close(); ws = null; }

  const url = getWsUrl();
  document.getElementById("ws-url-display").textContent = url;
  setStatus("conn", "CONNECTING...");

  try {
    ws = new WebSocket(url);
  } catch(e) {
    setStatus("error", "INVALID URL");
    return;
  }

  ws.onopen = () => {
    setStatus("live", "LIVE");
    // keepalive ping
    setInterval(() => {
      if (ws?.readyState === WebSocket.OPEN)
        ws.send(JSON.stringify({type:"ping"}));
    }, 30000);
  };

  ws.onmessage = e => {
    try { handleMessage(JSON.parse(e.data)); }
    catch {}
  };

  ws.onclose = () => {
    setStatus("error", "DISCONNECTED — reconnecting...");
    setTimeout(connectWS, 3000);
  };

  ws.onerror = () => setStatus("error", "CONNECTION ERROR");
}

function setStatus(cls, text) {
  const dot = document.getElementById("dot");
  dot.className = "status-dot " + cls;
  document.getElementById("status-text").textContent = text;
}

// ── MESSAGE HANDLER ──────────────────────────────────────────────────────────
function handleMessage(msg) {
  if (msg.type === "pong") return;

  if (msg.type === "init" || msg.type === "scan") {
    // Update stats
    document.getElementById("stat-scans").textContent  = msg.scanCount || 0;
    document.getElementById("stat-tokens").textContent = msg.tokenCount || 0;
    if (msg.ts) document.getElementById("last-scan").textContent =
      "  updated " + fmtTime(msg.ts);

    // Merge tokens
    if (msg.tokens) {
      for (const t of msg.tokens) {
        const prev = tokenStore.get(t.address);
        tokenStore.set(t.address, { ...t, _prev: prev });
      }
    }
    applyFilters();
  }

  if (msg.type === "alert") {
    pushAlert(msg);
  }

  if (msg.type === "error") {
    setStatus("error", "SERVER ERROR: " + msg.message);
  }
}

// ── FILTERING + SORTING ──────────────────────────────────────────────────────
function setFilter(btn, filter) {
  document.querySelectorAll("[data-filter]").forEach(b => b.classList.remove("active","danger"));
  btn.classList.add("active");
  if (filter === "strong_sell") btn.classList.add("danger");
  activeFilter = filter;
  applyFilters();
}

function applyFilters() {
  sortBy = document.getElementById("sort-select").value;
  const minLiq   = parseFloat(document.getElementById("min-liq").value)   || 0;
  const minVol5m = parseFloat(document.getElementById("min-vol5m").value) || 0;
  const minScore = parseFloat(document.getElementById("min-score").value) || 0;

  let list = [...tokenStore.values()].filter(t => {
    if (t.liquidity < minLiq)   return false;
    if (t.vol5m     < minVol5m) return false;
    if (t.score     < minScore) return false;
    const ageH = (Date.now() - t.pairCreatedAt) / 3600000;
    if (activeFilter === "strong_buy"  && t.verdict !== "STRONG BUY")  return false;
    if (activeFilter === "buy"         && !t.verdict.includes("BUY"))  return false;
    if (activeFilter === "strong_sell" && t.verdict !== "STRONG SELL") return false;
    if (activeFilter === "new1h" && ageH >= 1)  return false;
    if (activeFilter === "new6h" && ageH >= 6)  return false;
    return true;
  });

  // Sort
  list.sort((a,b) => {
    if (sortBy === "score")     return b.score - a.score;
    if (sortBy === "vol5m")     return (b.vol5m||0) - (a.vol5m||0);
    if (sortBy === "c5m")       return (b.c5m||0) - (a.c5m||0);
    if (sortBy === "c1h")       return (b.c1h||0) - (a.c1h||0);
    if (sortBy === "liquidity") return (b.liquidity||0) - (a.liquidity||0);
    if (sortBy === "age")       return b.pairCreatedAt - a.pairCreatedAt;
    return 0;
  });

  filteredList = list;
  renderTable();
}

// ── TABLE RENDER ─────────────────────────────────────────────────────────────
function renderTable() {
  const tbody = document.getElementById("tbody");
  const empty = document.getElementById("table-empty");

  if (filteredList.length === 0) {
    tbody.innerHTML = "";
    empty.style.display = "block";
    empty.textContent = tokenStore.size === 0
      ? "ENTER YOUR RAILWAY WEBSOCKET URL ABOVE AND CLICK CONNECT"
      : "NO TOKENS MATCH CURRENT FILTERS";
    return;
  }
  empty.style.display = "none";

  // Build rows
  const rows = filteredList.map(t => {
    const prev = t._prev;
    const ageH = (Date.now() - t.pairCreatedAt) / 3600000;
    const total5m = t.buys5m + t.sells5m;
    const buyR5m  = total5m > 0 ? t.buys5m / total5m : 0.5;
    const sc      = scoreColor(t.score);
    const isNew   = t.isNew || !prev;

    const chgClass = v => v > 0 ? "pos" : v < 0 ? "neg" : "neu";
    const chgFmt   = v => (v > 0 ? "+" : "") + (v || 0).toFixed(1) + "%";

    const vClass = t.verdict === "STRONG BUY"  ? "v-sb"
                 : t.verdict === "BUY"          ? "v-b"
                 : t.verdict === "SELL"         ? "v-s"
                 : t.verdict === "STRONG SELL"  ? "v-ss"
                 : "v-n";

    const ageClass = ageH < 1 ? "new1" : ageH < 6 ? "new6" : "";

    const priceFlash = prev
      ? (t.priceUsd > prev.priceUsd ? "flash-buy" : t.priceUsd < prev.priceUsd ? "flash-sell" : "")
      : "";

    return `<tr data-addr="${t.address}"
      class="${priceFlash} ${isNew?'row-new row-enter':''} ${selectedAddr===t.address?'selected':''}"
      onclick="selectToken('${t.address}')">
      <td>
        <div class="sym">${escHtml(t.symbol)}</div>
        <div class="name-sub">${escHtml(t.name?.slice(0,20)||"")}</div>
      </td>
      <td class="price">${fmtPrice(t.priceUsd)}</td>
      <td class="chg ${chgClass(t.c5m)}">${chgFmt(t.c5m)}</td>
      <td class="chg ${chgClass(t.c1h)}">${chgFmt(t.c1h)}</td>
      <td><span class="verdict-badge ${vClass}">${t.verdict||"NEUTRAL"}</span></td>
      <td>
        <div class="score-bar-wrap">
          <div class="score-bar"><div class="score-bar-fill" style="width:${t.score}%;background:${sc}"></div></div>
          <span class="score-num" style="color:${sc}">${t.score}</span>
        </div>
      </td>
      <td>
        <div class="buysell">
          <span class="bs-b">${t.buys5m||0}</span>
          <span style="color:var(--border)">/</span>
          <span class="bs-s">${t.sells5m||0}</span>
          <div class="bs-bar"><div class="bs-fill" style="width:${(buyR5m*100).toFixed(0)}%"></div></div>
        </div>
      </td>
      <td class="liq-num hide-mobile">$${fmtN(t.liquidity)}</td>
      <td class="vol-num hide-mobile">$${fmtN(t.vol5m)}</td>
      <td class="hide-mobile"><span class="age-tag ${ageClass}">${ageStr(t.pairCreatedAt)}</span></td>
      <td class="dex-tag hide-mobile">${escHtml(t.dex||"")}</td>
    </tr>`;
  }).join("");

  tbody.innerHTML = rows;
}

// ── TOKEN DETAIL ─────────────────────────────────────────────────────────────
function selectToken(addr) {
  selectedAddr = addr;
  const t = tokenStore.get(addr);
  if (!t) return;

  // Highlight row
  document.querySelectorAll("tbody tr").forEach(r => r.classList.remove("selected"));
  document.querySelector(`tr[data-addr="${addr}"]`)?.classList.add("selected");

  const sc = scoreColor(t.score);
  const ageH = (Date.now()-t.pairCreatedAt)/3600000;
  const total24 = t.buys24h + t.sells24h;
  const buyR24  = total24 > 0 ? (t.buys24h/total24*100).toFixed(0) : "50";
  const dexUrl  = t.url || `https://dexscreener.com/solana/${t.pairAddr}`;
  const rugUrl  = `https://rugcheck.xyz/tokens/${t.address}`;
  const jupUrl  = `https://jup.ag/swap/SOL-${t.address}`;
  const pfUrl   = `https://pump.fun/${t.address}`;

  const sigHtml = (t.signals||[]).map(s =>
    `<div class="signal-item ${s.type}-${s.strength}">
      <span class="sig-label">${escHtml(s.label)}</span>
      <span class="sig-detail">${escHtml(s.detail||"")}</span>
    </div>`
  ).join("") || '<div style="color:var(--dim);font-size:10px;padding:4px">No signals</div>';

  document.getElementById("detail").innerHTML = `
    <div class="detail-sym">${escHtml(t.symbol)}</div>
    <div class="detail-name">${escHtml(t.name||"")} · ${escHtml(t.dex||"")}</div>
    <div class="detail-price">${fmtPrice(t.priceUsd)}</div>

    <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
      <span style="font-family:'Bebas Neue';font-size:32px;color:${sc}">${t.score}</span>
      <div>
        <div style="font-family:'Bebas Neue';font-size:14px;color:${sc};letter-spacing:2px">${t.verdict||"NEUTRAL"}</div>
        <div style="font-size:8px;color:var(--dim);letter-spacing:1px">SIGNAL SCORE</div>
      </div>
    </div>

    <div class="detail-grid">
      <div class="detail-cell">
        <div class="detail-cell-label">5M CHANGE</div>
        <div class="detail-cell-val" style="color:${(t.c5m||0)>=0?'var(--green)':'var(--red)'}">
          ${(t.c5m||0)>=0?'+':''}${(t.c5m||0).toFixed(2)}%
        </div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">1H CHANGE</div>
        <div class="detail-cell-val" style="color:${(t.c1h||0)>=0?'var(--green)':'var(--red)'}">
          ${(t.c1h||0)>=0?'+':''}${(t.c1h||0).toFixed(2)}%
        </div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">LIQUIDITY</div>
        <div class="detail-cell-val">$${fmtN(t.liquidity)}</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">VOL 5M</div>
        <div class="detail-cell-val">$${fmtN(t.vol5m)}</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">BUYS 5M / SELLS 5M</div>
        <div class="detail-cell-val">
          <span style="color:var(--green)">${t.buys5m||0}B</span>
          <span style="color:var(--muted)"> / </span>
          <span style="color:var(--red)">${t.sells5m||0}S</span>
        </div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">BUY RATIO 24H</div>
        <div class="detail-cell-val">${buyR24}%</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">PAIR AGE</div>
        <div class="detail-cell-val">${ageStr(t.pairCreatedAt)}</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">SAFETY</div>
        <div class="detail-cell-val" style="color:${t.safety?.score>=60?'var(--green)':t.safety?.score>=40?'var(--yellow)':'var(--red)'}">
          ${t.safety?.score||0} ${t.safety?.flags?.length?'('+t.safety.flags.join(', ')+')':'✓'}
        </div>
      </div>
    </div>

    <div style="font-size:9px;color:var(--dim);letter-spacing:2px;margin-bottom:6px">SIGNALS</div>
    <div class="signals-list">${sigHtml}</div>

    <div style="font-size:8px;color:var(--dim);letter-spacing:1px;margin-bottom:4px;word-break:break-all">${t.address||""}</div>

    <div class="detail-links">
      <a class="detail-link rug" href="${rugUrl}" target="_blank">RUGCHECK</a>
      <a class="detail-link jup" href="${jupUrl}" target="_blank">JUPITER</a>
      <a class="detail-link dex" href="${dexUrl}" target="_blank">DEXSCREENER</a>
    </div>
  `;
}

// ── ALERT LOG ────────────────────────────────────────────────────────────────
function pushAlert(msg) {
  const t = msg.token;
  if (!t) return;

  alertCount++;
  document.getElementById("stat-alerts").textContent = alertCount;
  document.getElementById("alert-count").textContent = alertCount;

  const wrap  = document.getElementById("alerts-wrap");
  const empty = document.getElementById("alerts-empty");
  if (empty) empty.remove();

  const cls = msg.verdict?.includes("BUY") ? "buy" : msg.verdict?.includes("SELL") ? "sell" : "warn";
  const item = document.createElement("div");
  item.className = `alert-item ${cls}`;
  item.innerHTML = `
    <div class="alert-sym" onclick="selectToken('${t.address}')" style="cursor:pointer">${escHtml(t.symbol)}</div>
    <div class="alert-body">
      <div class="alert-verdict" style="color:${cls==='buy'?'var(--green)':cls==='sell'?'var(--red)':'var(--yellow)'}">${escHtml(msg.verdict||"")}</div>
      <div class="alert-sigs">${(msg.signals||[]).map(s=>escHtml(s.label)).join(' · ')}</div>
    </div>
    <div class="alert-time">${fmtTime(Date.now())}</div>
  `;
  wrap.insertBefore(item, wrap.firstChild);

  // Trim to 50 alerts
  while (wrap.children.length > 50) wrap.removeChild(wrap.lastChild);
}

function clearAlerts() {
  document.getElementById("alerts-wrap").innerHTML =
    '<div class="alerts-empty" id="alerts-empty">No signals yet</div>';
  alertCount = 0;
  document.getElementById("stat-alerts").textContent = 0;
  document.getElementById("alert-count").textContent = 0;
}

// ── UTILS ────────────────────────────────────────────────────────────────────
function escHtml(s) {
  return String(s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

// Auto-refresh display every 5s (for age column etc)
setInterval(() => { if (filteredList.length) renderTable(); }, 5000);

// Auto-connect if served from Railway
window.onload = () => {
  const wsInput = document.getElementById("ws-input");
  if (location.hostname !== "localhost" && location.hostname !== "127.0.0.1") {
    const proto = location.protocol === "https:" ? "wss:" : "ws:";
    wsInput.value = `${proto}//${location.host}`;
    connectWS();
  }
};
</script>

